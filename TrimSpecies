# Get the current value of the pokemonspecies field
# Note: Field names in extensions are usually prefixed with 'raw'
species_value = document.get_meta_data_value("pokemonspecies")
log(species_value)
if species_value:
    # We take the first element of the list (Coveo metadata is often returned as a list)
    original_text = species_value[0]
    
    # Trim " Pokémon" from the end. 
    # .replace() is safe, or .split(" Pokémon")[0]
    trimmed_text = original_text.replace(" Pokémon", "").strip()
    log(trimmed_text)
    # Overwrite the field with the new value
    document.add_metadata({"pokemonspecies": trimmed_text})
